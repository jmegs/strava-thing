{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "strava-thing",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2025-08-21",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true,
	},
	"routes": [
		{ "pattern": "strava.john.zone", "custom_domain": true },
	],
	"kv_namespaces": [
		{
			"binding": "SESSIONS",
			"id": "b2409f0c1a6e44fb875bcca3a9e32910",
		},
	],
}
