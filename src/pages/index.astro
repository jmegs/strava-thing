---
import Base from "../layouts/Base.astro"
import StatHeader from "../components/StatHeader.astro"
import { RunList } from "../components/RunList"
import { listRunsForAthlete } from "../lib/services/runs-service"
import { getStatsForAthlete } from "../lib/services/stats-service"
import type { SessionData } from "../shared/types"
import type { RunSummary } from "../lib/format/runs"
import type { RunStats } from "../shared/stats"

const auth = (await Astro.session!.get("auth")) as SessionData
let runs: RunSummary[] = []
let stats: RunStats | null = null
try {
	const statsResult = await getStatsForAthlete(auth.athleteId)
	const runsResult = await listRunsForAthlete(auth.athleteId, { limit: 100 })
	stats = statsResult.dashboard
	runs = runsResult.runs
} catch (e) {
	console.error("Failed to fetch runs:", e)
}
---

<Base>
	{runs.length > 0 ? (
		<>
			{stats && <StatHeader stats={stats} />}
			<RunList client:load runs={runs} />
		</>
	) : (
		<div class="p-8 text-center">
			<p>Could not load runs. Strava may be down, or your session may have expired.</p>
			<a href="/auth/strava" class="underline mt-2 inline-block">Re-authenticate</a>
		</div>
	)}
</Base>
