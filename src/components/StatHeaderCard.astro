---
interface Props {
	title: string
	timeframe: string
	statlines: string[]
	class?: string
}

const { title, timeframe, statlines, class: className } = Astro.props
---

<div
	class:list={[
		"aspect-square flex flex-col justify-between px-4 py-3 border",
		className,
	]}
>
	<div class="flex justify-between items-center">
		<span>{title}</span>
		<span>{timeframe}</span>
	</div>

	<div class="flex flex-col space-y-1">
		{statlines.map((line) => <span>{line}</span>)}
	</div>
</div>
